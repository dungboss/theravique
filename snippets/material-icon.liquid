{%- assign _is_hex = false -%}
{%- if custom_color contains '#' -%}{%- assign _is_hex = true -%}{%- endif -%}
<span class="material-icon material-symbols-outlined{% if filled %} filled{% endif %}{% if custom_color != blank and _is_hex == false %} material-icon--custom-color color-icon-{{ custom_color }}{% endif %}{{ class }}"{% if _is_hex %} style="color:{{ custom_color }};"{% endif %}>
  {{ icon | strip | downcase | replace: ' ', '_' }}
</span>
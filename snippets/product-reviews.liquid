{% comment %} Product reviews section for hooded pillow {% endcomment %}
<div id="reviews" class="product-reviews page-width" style="margin-top:5rem;margin-bottom:5rem;">
  <h2 style="font-size:2.8rem;font-weight:700;text-align:center;margin-bottom:2rem;">Customer Reviews</h2>

  {%- comment -%} Rating summary {%- endcomment -%}
  <div class="product-reviews__summary" style="display:flex;flex-wrap:wrap;justify-content:center;align-items:flex-start;gap:3rem;max-width:800px;margin:0 auto 3rem;">

    <div style="text-align:center;">
      <div style="font-size:5rem;font-weight:700;line-height:1;">4.7</div>
      <div style="display:flex;gap:2px;justify-content:center;margin:6px 0;color:#FBBF24;">
        {%- for i in (1..5) -%}
          <svg width="20" height="20" viewBox="0 0 576 512" fill="currentColor" aria-hidden="true"><path d="M316.9 18C311.6 7 300.4 0 288.1 0s-23.4 7-28.8 18L195 150.3 51.4 171.5c-12 1.8-22 10.2-25.7 21.7s-.7 24.2 7.9 32.7L137.8 329 113.2 474.7c-2 12 3 24.2 12.9 31.3s23 8 33.8 2.3l128.3-68.5 128.3 68.5c10.8 5.7 23.9 4.9 33.8-2.3s14.9-19.3 12.9-31.3L438.5 329 542.7 225.9c8.6-8.5 11.7-21.2 7.9-32.7s-13.7-19.9-25.7-21.7L381.2 150.3 316.9 18z"/></svg>
        {%- endfor -%}
      </div>
      <div style="font-size:1.25rem;color:#6B7280;">Based on 260 reviews</div>
    </div>

    <div style="flex:1;min-width:200px;max-width:320px;">
      {%- assign bars = '5,80|4,15|3,3|2,1|1,1' | split: '|' -%}
      {%- for bar in bars -%}
        {%- assign parts = bar | split: ',' -%}
        <div style="display:flex;align-items:center;gap:8px;font-size:0.8rem;margin-bottom:6px;">
          <span style="width:44px;color:#6B7280;">{{ parts[0] }} stars</span>
          <div style="flex:1;height:10px;background:#F3F4F6;border-radius:99px;overflow:hidden;">
            <div style="height:100%;width:{{ parts[1] }}%;background:#FBBF24;border-radius:99px;"></div>
          </div>
          <span style="width:28px;text-align:right;color:#9CA3AF;">{{ parts[1] }}%</span>
        </div>
      {%- endfor -%}
    </div>

  </div>

  {%- comment -%} Review cards {%- endcomment -%}
  <div class="product-reviews__grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.5rem;">

    {%- assign review_data = 'Sarah J.|May 12, 2024|Great for long flights!|I brought this pillow on a 14-hour flight and it truly saved my neck. The hood helps perfectly block out the light.|5,
Michael T.|May 02, 2024|Very comfortable|Good quality memory foam, does not flatten after multiple uses. The black color looks very clean.|4,
Emily R.|Apr 28, 2024|Good product but a bit bulky|The pillow hugs the neck very well but takes up a bit of space in a small backpack. On the plus side, I sleep very well with it.|4,
David L.|Apr 15, 2024|Worth the money|Compared to cheap inflatable pillows, this is a worthwhile upgrade. I bought another one for my wife.|5,
Jessica W.|Apr 05, 2024|The pink color is very cute|Product is exactly as pictured, beautiful color, soft cover material. Tried using it while working and it felt very okay.|5,
John D.|Mar 20, 2024|Good support|The raised design on the sides keeps the head from tilting when nodding off on the bus.|5' | split: ',' -%}

    {%- assign reviews = "Sarah J.|May 12, 2024|Great for long flights!|I brought this pillow on a 14-hour flight and it truly saved my neck. The hood helps perfectly block out the light.|5;Michael T.|May 02, 2024|Very comfortable|Good quality memory foam, does not flatten after multiple uses. The black color looks very clean.|4;Emily R.|Apr 28, 2024|Good product but a bit bulky|The pillow hugs the neck very well but takes up a bit of space in a small backpack.|4;David L.|Apr 15, 2024|Worth the money|Compared to cheap inflatable pillows, this is a worthwhile upgrade. I bought another one for my wife.|5;Jessica W.|Apr 05, 2024|The pink color is very cute|Product is exactly as pictured, beautiful color, soft cover material.|5;John D.|Mar 20, 2024|Good support|The raised design on the sides keeps the head from tilting when nodding off on the bus.|5" | split: ';' -%}

    {%- for review in reviews -%}
      {%- assign fields = review | split: '|' -%}
      {%- assign reviewer = fields[0] -%}
      {%- assign date = fields[1] -%}
      {%- assign title = fields[2] -%}
      {%- assign body = fields[3] -%}
      {%- assign rating = fields[4] | plus: 0 -%}
      <div style="border:1px solid #F3F4F6;background:#F9FAFB;padding:1.5rem;border-radius:1rem;">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.75rem;">
          <div style="display:flex;gap:2px;color:#FBBF24;">
            {%- for i in (1..5) -%}
              {%- if i <= rating -%}
                <svg width="14" height="14" viewBox="0 0 576 512" fill="currentColor" aria-hidden="true"><path d="M316.9 18C311.6 7 300.4 0 288.1 0s-23.4 7-28.8 18L195 150.3 51.4 171.5c-12 1.8-22 10.2-25.7 21.7s-.7 24.2 7.9 32.7L137.8 329 113.2 474.7c-2 12 3 24.2 12.9 31.3s23 8 33.8 2.3l128.3-68.5 128.3 68.5c10.8 5.7 23.9 4.9 33.8-2.3s14.9-19.3 12.9-31.3L438.5 329 542.7 225.9c8.6-8.5 11.7-21.2 7.9-32.7s-13.7-19.9-25.7-21.7L381.2 150.3 316.9 18z"/></svg>
              {%- else -%}
                <svg width="14" height="14" viewBox="0 0 576 512" fill="#D1D5DB" aria-hidden="true"><path d="M316.9 18C311.6 7 300.4 0 288.1 0s-23.4 7-28.8 18L195 150.3 51.4 171.5c-12 1.8-22 10.2-25.7 21.7s-.7 24.2 7.9 32.7L137.8 329 113.2 474.7c-2 12 3 24.2 12.9 31.3s23 8 33.8 2.3l128.3-68.5 128.3 68.5c10.8 5.7 23.9 4.9 33.8-2.3s14.9-19.3 12.9-31.3L438.5 329 542.7 225.9c8.6-8.5 11.7-21.2 7.9-32.7s-13.7-19.9-25.7-21.7L381.2 150.3 316.9 18z"/></svg>
              {%- endif -%}
            {%- endfor -%}
          </div>
          <span style="font-size:0.75rem;color:#9CA3AF;">{{ date }}</span>
        </div>
        <h4 style="font-weight:700;font-size:1.5rem;margin:0 0 10px;">{{ title }}</h4>
        <p style="font-size:1.2rem;color:#4B5563;margin:0 0 1rem;line-height:1.6;">{{ body }}</p>
        <div style="font-size:1.05rem;color:#6B7280;display:flex;justify-content:space-between;">
          <span style="font-weight:600;color:#374151;">{{ reviewer }} <span style="color:#16A34A;">&#10003; Verified Buyer</span></span>
        </div>
      </div>
    {%- endfor -%}

  </div>
</div>

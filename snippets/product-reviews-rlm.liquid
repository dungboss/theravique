{% comment %} Product reviews with customer photos – Red Light Massager {% endcomment %}
<div id="reviews-rlm" class="rlm-reviews page-width" style="padding:4rem 1.5rem;background:#fff;">
  <style>
    #reviews-rlm .rlm-reviews__summary {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: flex-start;
      gap: 3rem;
      max-width: 840px;
      margin: 0 auto 3.5rem;
    }

    #reviews-rlm .rlm-reviews__distribution {
      flex: 1;
      min-width: 240px;
      max-width: 360px;
      display: grid;
      gap: 0.75rem;
    }

    #reviews-rlm .rlm-reviews__distribution-row {
      display: grid;
      grid-template-columns: auto minmax(140px, 1fr) auto;
      align-items: center;
      gap: 0.75rem;
    }

    #reviews-rlm .rlm-reviews__distribution-label {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      min-width: 92px;
      color: #6B7280;
      font-size: 1rem;
      white-space: nowrap;
    }

    #reviews-rlm .rlm-reviews__distribution-stars {
      display: inline-flex;
      align-items: center;
      gap: 0.12rem;
      color: #F59E0B;
    }

    #reviews-rlm .rlm-reviews__distribution-track {
      height: 12px;
      background: #FFFFFF;
      border: 1px solid #FCD9B6;
      border-radius: 999px;
      overflow: hidden;
      box-shadow: inset 0 1px 2px rgba(17, 24, 39, 0.05);
    }

    #reviews-rlm .rlm-reviews__distribution-fill {
      display: block;
      height: 100%;
      background: linear-gradient(90deg, #F59E0B 0%, #FB923C 100%);
      border-radius: 999px;
    }

    #reviews-rlm .rlm-reviews__distribution-percent {
      width: 42px;
      text-align: right;
      color: #9A3412;
      font-size: 0.95rem;
      font-weight: 600;
      white-space: nowrap;
    }

    @media screen and (max-width: 749px) {
      #reviews-rlm .rlm-reviews__summary {
        gap: 2rem;
      }

      #reviews-rlm .rlm-reviews__distribution-row {
        grid-template-columns: 1fr;
        gap: 0.45rem;
      }

      #reviews-rlm .rlm-reviews__distribution-label,
      #reviews-rlm .rlm-reviews__distribution-percent {
        width: auto;
      }

      #reviews-rlm .rlm-reviews__distribution-percent {
        text-align: left;
      }
    }
  </style>

  <h2 style="font-size:2.8rem;font-weight:700;text-align:center;margin:0 0 0.5rem;">What Our Customers Say</h2>
  <p style="text-align:center;color:#6B7280;font-size:1.25rem;margin:0 0 2.5rem;">Real results from real people</p>

  {%- comment -%} Rating summary bar {%- endcomment -%}
  <div class="rlm-reviews__summary">
    <div style="text-align:center;">
      <div style="font-size:5rem;font-weight:700;line-height:1;color:#111;">4.8</div>
      <div style="display:flex;gap:3px;justify-content:center;margin:8px 0;color:#ffcc00;">
        {%- for i in (1..5) -%}
          <svg width="22" height="22" viewBox="0 0 576 512" fill="currentColor"><path d="M316.9 18C311.6 7 300.4 0 288.1 0s-23.4 7-28.8 18L195 150.3 51.4 171.5c-12 1.8-22 10.2-25.7 21.7s-.7 24.2 7.9 32.7L137.8 329 113.2 474.7c-2 12 3 24.2 12.9 31.3s23 8 33.8 2.3l128.3-68.5 128.3 68.5c10.8 5.7 23.9 4.9 33.8-2.3s14.9-19.3 12.9-31.3L438.5 329 542.7 225.9c8.6-8.5 11.7-21.2 7.9-32.7s-13.7-19.9-25.7-21.7L381.2 150.3 316.9 18z"/></svg>
        {%- endfor -%}
      </div>
      <div style="font-size:1.2rem;color:#6B7280;">Based on 9,984 reviews</div>
    </div>
    <div class="rlm-reviews__distribution">
      {%- assign bars = '5,76|4,17|3,5|2,1|1,1' | split: '|' -%}
      {%- for bar in bars -%}
        {%- assign parts = bar | split: ',' -%}
        {%- assign bar_stars = parts[0] | plus: 0 -%}
        {%- assign bar_percent = parts[1] | plus: 0 -%}
        <div class="rlm-reviews__distribution-row">
          <div class="rlm-reviews__distribution-label">
            <span>{{ bar_stars }}</span>
            <span class="rlm-reviews__distribution-stars" aria-hidden="true">
              {%- for i in (1..5) -%}
                <svg width="12" height="12" viewBox="0 0 576 512" fill="{% if i <= bar_stars %}currentColor{% else %}#E5E7EB{% endif %}"><path d="M316.9 18C311.6 7 300.4 0 288.1 0s-23.4 7-28.8 18L195 150.3 51.4 171.5c-12 1.8-22 10.2-25.7 21.7s-.7 24.2 7.9 32.7L137.8 329 113.2 474.7c-2 12 3 24.2 12.9 31.3s23 8 33.8 2.3l128.3-68.5 128.3 68.5c10.8 5.7 23.9 4.9 33.8-2.3s14.9-19.3 12.9-31.3L438.5 329 542.7 225.9c8.6-8.5 11.7-21.2 7.9-32.7s-13.7-19.9-25.7-21.7L381.2 150.3 316.9 18z"/></svg>
              {%- endfor -%}
            </span>
          </div>
          <div class="rlm-reviews__distribution-track" aria-hidden="true">
            <span class="rlm-reviews__distribution-fill" style="width:{{ bar_percent }}%;"></span>
          </div>
          <span class="rlm-reviews__distribution-percent">{{ bar_percent }}%</span>
        </div>
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%} Full review cards grid {%- endcomment -%}
  {%- assign full_reviews = "Lily S.|May 2025|5|Back pain finally gone!|I've been using this for two weeks and my chronic back pain has significantly reduced. The heat and suction combination is incredible.|0,Marcus T.|Apr 2025|5|Recovery game changer|The remote control makes it so easy to adjust. I use it every evening after the gym and my recovery time has improved dramatically.|1,Sarah K.|Apr 2025|5|Love the red light feature|I was skeptical at first, but after one week I noticed real improvements in my shoulder mobility and less tension headaches.|2,Jennifer L.|Mar 2025|5|Office worker approved!|After sitting at a desk all day my neck and shoulders are always tight. This device gives me spa-level relief at home every night.|3,Daniel M.|Mar 2025|5|Athlete must-have|As an athlete I need effective recovery tools. The red light therapy feature is a bonus I didn't expect — my legs feel so much better after use.|4,Amanda P.|Feb 2025|5|Feels like a professional massage|I've tried many massage devices over the years, but this is on another level. Suction + heat + red light unlike anything else I've used.|5" | split: ',' -%}

  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:1.5rem;">
    {%- for review in full_reviews -%}
      {%- assign fields = review | split: '|' -%}
      {%- assign rv_name   = fields[0] -%}
      {%- assign rv_date   = fields[1] -%}
      {%- assign rv_rating = fields[2] | plus: 0 -%}
      {%- assign rv_title  = fields[3] -%}
      {%- assign rv_body   = fields[4] -%}
      {%- assign rv_img    = fields[5] | plus: 0 -%}
      <div style="border:1px solid #F3F4F6;border-radius:14px;overflow:hidden;background:#FAFAFA;">
        {%- if product.images[rv_img] != blank -%}
          <div style="width:100%;aspect-ratio:4/3;overflow:hidden;">
            <img src="{{ product.images[rv_img] | image_url: width: 600 }}" alt="Customer review photo" loading="lazy" style="width:100%;height:100%;object-fit:cover;">
          </div>
        {%- endif -%}
        <div style="padding:1.25rem;">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.6rem;">
            <div style="display:flex;gap:2px;color:#ffcc00;">
              {%- for i in (1..5) -%}
                {%- if i <= rv_rating -%}
                  <svg width="14" height="14" viewBox="0 0 576 512" fill="currentColor"><path d="M316.9 18C311.6 7 300.4 0 288.1 0s-23.4 7-28.8 18L195 150.3 51.4 171.5c-12 1.8-22 10.2-25.7 21.7s-.7 24.2 7.9 32.7L137.8 329 113.2 474.7c-2 12 3 24.2 12.9 31.3s23 8 33.8 2.3l128.3-68.5 128.3 68.5c10.8 5.7 23.9 4.9 33.8-2.3s14.9-19.3 12.9-31.3L438.5 329 542.7 225.9c8.6-8.5 11.7-21.2 7.9-32.7s-13.7-19.9-25.7-21.7L381.2 150.3 316.9 18z"/></svg>
                {%- else -%}
                  <svg width="14" height="14" viewBox="0 0 576 512" fill="#E5E7EB"><path d="M316.9 18C311.6 7 300.4 0 288.1 0s-23.4 7-28.8 18L195 150.3 51.4 171.5c-12 1.8-22 10.2-25.7 21.7s-.7 24.2 7.9 32.7L137.8 329 113.2 474.7c-2 12 3 24.2 12.9 31.3s23 8 33.8 2.3l128.3-68.5 128.3 68.5c10.8 5.7 23.9 4.9 33.8-2.3s14.9-19.3 12.9-31.3L438.5 329 542.7 225.9c8.6-8.5 11.7-21.2 7.9-32.7s-13.7-19.9-25.7-21.7L381.2 150.3 316.9 18z"/></svg>
                {%- endif -%}
              {%- endfor -%}
            </div>
            <span style="font-size:0.75rem;color:#9CA3AF;">{{ rv_date }}</span>
          </div>
          <h4 style="font-size:1.4rem;font-weight:700;margin:0 0 8px;">{{ rv_title }}</h4>
          <p style="font-size:1.15rem;color:#4B5563;line-height:1.6;margin:0 0 1rem;">{{ rv_body }}</p>
          <div style="display:flex;align-items:center;gap:8px;">
            <div style="width:32px;height:32px;border-radius:50%;background:#CC1C1C;display:flex;align-items:center;justify-content:center;color:#fff;font-size:0.85rem;font-weight:700;flex-shrink:0;">{{ rv_name | slice: 0 }}</div>
            <span style="font-weight:600;color:#374151;font-size:1.05rem;">{{ rv_name }} <span style="color:#16A34A;font-weight:400;">&#10003; Verified Buyer</span></span>
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>

</div>

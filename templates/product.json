        "custom_liquid": "<style>.ec-wrap{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;max-width:1200px;margin:0 auto;padding:0 20px;}.ec-content h2{font-size:3.6rem;line-height:1.2;margin:0 0 20px;color:#111;}.ec-desc{color:#333;margin:0 0 28px;}.ec-btn{display:inline-block;padding:16px 36px;background:#111;color:#fff;font-size:1.5rem;border-radius:8px;text-decoration:none;}.ec-img{width:100%;border-radius:12px;display:block;}@media(max-width:768px){.ec-wrap{grid-template-columns:1fr;gap:32px;}.ec-content h2{font-size:2.6rem;}.ec-content{text-align:center;}.ec-btn{display:block;text-align:center;}}</style><div class=\"ec-wrap\"><div class=\"ec-content\"><h2 class=\"pp-font-semibold\">Embarrassing cellulite and poor circulation</h2><p class=\"ec-desc pp-text-base\">Combine gentle suction with heat and light therapy to improve blood flow and soften skin texture. Regular short sessions help reduce bumpy appearance and leave skin smoother and more confident.</p><a class=\"ec-btn pp-font-semibold\" href=\"#ProductSubmitButton-template--27477874868507__main\">Get Mine Now</a></div><img class=\"ec-img\" src=\"{{ product.images[3] | img_url: '800x' }}\" alt=\"Cordless Portable Design\" loading=\"lazy\"/></div>",

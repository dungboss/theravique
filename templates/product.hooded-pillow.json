{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "rating_stars": {
          "type": "rating-stars",
          "settings": {
            "rating": 4.7,
            "label": "(260 Reviews)",
            "star_color": "#FBBF24",
            "scroll_id": "reviews"
          }
        },
        "title": {
          "type": "product_title",
          "settings": {}
        },
        "price": {
          "type": "product_price",
          "settings": {}
        },
        "promo_block": {
          "type": "custom-liquid",
          "settings": {
            "custom_liquid": "<div style='background:#EFF6FF;border:1px solid #DBEAFE;border-radius:8px;padding:10px 14px;margin-bottom:8px;display:flex;align-items:center;gap:10px;font-size:13px;'><span style='background:#2563EB;color:#fff;font-size:11px;font-weight:700;padding:3px 8px;border-radius:4px;white-space:nowrap;'>OFFER</span><span>Buy 1 Get 1 50% Off. Use code: <strong>BOGO50</strong></span></div>"
          }
        },
        "variant_picker": {
          "type": "product_product-variant-picker-block",
          "settings": {
            "picker_type": "button",
            "color_swatches_enabled": true
          }
        },
        "quantity_selector": {
          "type": "product_quantity-selector",
          "settings": {}
        },
        "buy_buttons": {
          "type": "product_buy-buttons",
          "settings": {
            "show_dynamic_checkout": true
          }
        },
        "payment_badges": {
          "type": "payment-badges",
          "settings": {}
        },
        "accordion_why": {
          "type": "collapsible-row",
          "settings": {
            "heading": "Why Choose Memory Foam Hooded Travel Pillow?",
            "open": true,
            "content": "<p>Our pillows use premium memory foam to provide maximum neck support, feature an ergonomic design to prevent fatigue, and come with a convenient hood to help you easily fall asleep anywhere.</p>"
          }
        },
        "accordion_material": {
          "type": "collapsible-row",
          "settings": {
            "heading": "100% Soft Cotton Cover Material",
            "open": false,
            "content": "<p>The pillow cover is removable and machine washable. The breathable cotton material is safe for sensitive skin.</p>"
          }
        },
        "accordion_breathable": {
          "type": "collapsible-row",
          "settings": {
            "heading": "Optimal Breathable Design",
            "open": false,
            "content": "<p>The internal ventilation hole structure helps dissipate heat, preventing sweating when used for long periods.</p>"
          }
        },
        "accordion_shipping": {
          "type": "collapsible-row",
          "settings": {
            "heading": "Shipping & Returns",
            "open": false,
            "content": "<p>Free nationwide shipping for orders over $50. Easy returns within 30 days for any manufacturing defects.</p>"
          }
        }
      },
      "block_order": [
        "rating_stars",
        "title",
        "price",
        "promo_block",
        "variant_picker",
        "quantity_selector",
        "buy_buttons",
        "payment_badges",
        "accordion_why",
        "accordion_material",
        "accordion_breathable",
        "accordion_shipping"
      ],
      "settings": {
        "media_size": "large",
        "enable_sticky_info": true,
        "show_rating": false
      }
    },
    "trust_badges": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "{% render 'trust-badges' %}"
      }
    },
    "related_products": {
      "type": "related-products",
      "settings": {
        "heading": "You may also like",
        "products_to_show": 4
      }
    },
    "reviews": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "{% render 'product-reviews' %}"
      }
    }
  },
  "order": [
    "main",
    "trust_badges",
    "related_products",
    "reviews"
  ]
}

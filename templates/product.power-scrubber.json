    "facebook_testimonials_product_gallery": {
      "type": "facebook-testimonials",
      "blocks": {
        "column_Y9BLnV": {
          "type": "column",
          "settings": {
            "post_author": "Sarah Mitchell",
            "post_author_avatar": "shopify://shop_images/381aaab70e9decd5fac1e9d21500eb89.webp",
            "post_author_verified": false,
            "post_time": "22h ago",
            "post_text": "<p>This was awesome, didn't know they made this usually scrub tile by hand when I clean and this made clean my shower a breeze especially after washing my dog. Does not make a lot of noise, when it comes to the settings I think there could a higher setting but even the highest one gets everything clean.<br/><br/></p>",
            "post_image": "shopify://shop_images/717DITlKk9L.jpg",
            "post_reactions": "like, love, care",
            "post_reactions_text": "892",
            "post_comments_text": "415 Comments",
            "comment_1_author": "Comment author",
            "comment_1_author_verified": false,
